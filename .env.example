# Supabase (required for auth/template/media features)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: if you later add server-side admin actions
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LLM provider (required for AI intake draft generation)
LLM_API_KEY=your-llm-api-key
LLM_MODEL=gpt-4o-mini
# Optional override for OpenAI-compatible gateways
LLM_API_BASE_URL=https://api.openai.com/v1

# Cloudflare (optional for CI/CD automation; local deploy can use `wrangler login`)
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
